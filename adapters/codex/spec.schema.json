{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "fable-forge spec",
  "type": "object",
  "required": ["restated_goal", "non_goals", "must_read", "rejected_alternatives", "acceptance_criteria"],
  "properties": {
    "grade": {"type": "string", "enum": ["LIGHT", "STANDARD", "HEAVY"]},
    "phase": {"type": "string"},
    "raw_goal": {"type": "string"},
    "restated_goal": {"type": "string", "minLength": 1,
      "description": "Intent + constraint envelope: 'achieve X without violating Y, scoped to Z'. NOT the raw ask verbatim."},
    "non_goals": {"type": "array", "minItems": 1, "items": {"type": "string"},
      "description": "The over-broad version you are NOT doing."},
    "ambiguities": {"type": "array", "items": {
      "type": "object", "required": ["question", "resolution", "authority"],
      "properties": {"question": {"type": "string"}, "resolution": {"type": "string"}, "authority": {"type": "string"}}}},
    "must_read": {"type": "array", "minItems": 1, "items": {
      "type": "object", "required": ["path", "authority_reason"],
      "properties": {"path": {"type": "string"},
        "authority_reason": {"type": "string", "description": "the contract/boundary this file owns that the change must satisfy"}}}},
    "constraints": {"type": "object", "properties": {
      "architectural": {"type": "array", "items": {"type": "string"}},
      "invariant": {"type": "array", "items": {"type": "string"}},
      "convention": {"type": "array", "items": {"type": "string"}}}},
    "rejected_alternatives": {"type": "array", "minItems": 2, "items": {
      "type": "object", "required": ["category", "alternative", "broken_boundary"],
      "properties": {
        "category": {"type": "string", "enum": ["tempting_shortcut", "architecture", "scope", "compatibility"]},
        "alternative": {"type": "string"},
        "broken_boundary": {"type": "string", "description": "the principle/invariant/cost this option violates"}}}},
    "risks": {"type": "array", "items": {
      "type": "object", "required": ["risk", "severity", "mitigation"],
      "properties": {
        "risk": {"type": "string"},
        "severity": {"type": "string", "enum": ["low", "medium", "high", "blocking"]},
        "mitigation": {"type": "string", "description": "runnable/checkable, not 'be careful'"},
        "acceptance_ref": {"type": "string", "description": "required for high/blocking — the acceptance criterion that covers it"}}}},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {
      "type": "object", "required": ["criterion", "verify"],
      "properties": {
        "criterion": {"type": "string"},
        "verify": {"type": "object", "required": ["type", "value"],
          "properties": {"type": {"type": "string"}, "value": {"type": "string", "description": "a runnable command or falsifiable check"}}},
        "evidence": {"type": "string", "description": "live output from running verify.value — filled at VERIFY"}}}}
  }
}
